# ─────────────────────────────────────────────────
# GAMNON MODERN — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────

# Apify — for Phase 0.5 pre-flight and Phase 1 full scrape
APIFY_TOKEN=

# Anthropic — for Phase 4 translation pipeline
ANTHROPIC_API_KEY=

# Hugging Face — for Phase 2 image upscaling (optional: local Real-ESRGAN preferred)
HF_TOKEN=

# ─── Budget guardrails (USD) ───────────────────
# Set these BEFORE running any paid pipeline step.
# The pipeline will halt at 80% of each ceiling.
APIFY_BUDGET_USD=
TRANSLATION_BUDGET_USD=
